{
  "name": "derby-owners-club",
  "version": "1.0.0",
  "description": "Derby Owners Club remote controller",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:frontend && electron-builder",
    "dev": "cd frontend && npm run dev"
  },
  "build": {
    "appId": "com.derbyownersclub.app",
    "productName": "Derby Owners Club",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerHeaderIcon": "resources/icon.ico"
    },
    "files": [
      "main.js",
      "backend/**/*",
      "frontend/dist/**/*",
      "resources/mediamtx.yml",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/mediamtx.exe",
        "to": "mediamtx.exe"
      }
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}